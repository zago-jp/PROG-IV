    // ===============================
    // Background
    // ===============================
    "background.enabled": true,
    "background.editor": {
        "useFront": true,
        "style": {
            "background-position": "center",
            "background-size": "cover",
            "opacity": 0.05,
            "filter": "brightness(0.45) contrast(1.15) saturate(1.1)"
        },
        "images": [
            "file:///C:/Users/jaoza/OneDrive/Imagens/FATE2.webp",
            "file:///C:/Users/jaoza/OneDrive/Imagens/saber1.jpg",
            "file:///C:/Users/jaoza/OneDrive/Imagens/SABE.jpg"
        ],
        "interval": 60,
        "random": true
    },

